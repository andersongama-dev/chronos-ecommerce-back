generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int    @id(map: "Users_pkey") @default(autoincrement())
  name     String
  email    String @unique(map: "Users_email_key")
  password String
  carts    Cart[]
}

model Watch {
  id            Int      @id @default(autoincrement())
  name          String
  brand         Brand
  price         Decimal  @db.Decimal(10, 2)
  gender        Gender
  style         Style
  caseMaterial  Material
  strapMaterial Material
  strapColor    Color
  imageUrl      String
  slug          String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cartItems CartItem[]
}

model Cart {
  id        Int        @id @default(autoincrement())
  userId    Int
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        Int      @id @default(autoincrement())
  cartId    Int
  watchId   Int
  quantity  Int      @default(1)
  priceAtAddition Decimal @db.Decimal(10, 2)

  cart   Cart  @relation(fields: [cartId], references: [id], onDelete: Cascade)
  watch  Watch @relation(fields: [watchId], references: [id])

  @@unique([cartId, watchId])
}

enum Brand {
  ROLEX
  CASIO
  SEIKO
  OMEGA
  TAG_HEUER
  TISSOT
}

enum Gender {
  MEN
  WOMEN
  UNISEX
}

enum Style {
  CASUAL
  SPORT
  LUXURY
  CLASSIC
  DIVER
}

enum Material {
  STAINLESS_STEEL
  GOLD
  TITANIUM
  CERAMIC
  LEATHER
  RUBBER
  METAL
  NYLON
}

enum Color {
  BLACK
  BROWN
  SILVER
  GOLD
  BLUE
}
